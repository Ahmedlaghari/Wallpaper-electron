{
  "name": "time-wallpaper",
  "version": "1.0.0",
  "description": "Time Wallpaper App",
  "author": "Your Name",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.yourname.timewallpaper",
    "productName": "Time Wallpaper",
    "npmRebuild": true,
    "nodeGypRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "config.json",
      "icon.png"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/canvas/**",
      "node_modules/wallpaper/**",
      "node_modules/bindings/**",
      "node_modules/@napi-rs/**",
      "config.json",
      "icon.png",
      "fonts/*"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "canvas": "^3.2.1",
    "sharp": "^0.34.5",
    "wallpaper": "^7.2.1"
  }
}
